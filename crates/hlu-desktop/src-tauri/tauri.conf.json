{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Homelab Utils",
  "version": "0.2.0",
  "identifier": "dev.kodingkorp.homelab-utils",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Homelab Utils",
        "width": 1100,
        "height": 720,
        "minWidth": 820,
        "minHeight": 560,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Discover and manage your homelab devices.",
    "longDescription": "A native, blazing-fast desktop cockpit for your homelab: discover devices on your LAN, name them, check SSH, and connect in one click.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE2OENCNDdCMEUwRjM5NDIKUldSQ09ROE9lN1NNcG1aRHJ6RjNRMHg3ckFpS2xQQUg0K0drVlZBNVBibFlQaXJ1WmRwVGU0aWYK",
      "endpoints": [
        "https://github.com/KodingKorp/homelab-utils/releases/latest/download/latest.json"
      ]
    }
  }
}
